
CREATE TABLE usuarios (
	id SERIAL PRIMARY KEY,
	nome VARCHAR(200) NOT NULL,
	login VARCHAR(100) NOT NULL,
	senha VARCHAR(300) NOT NULL UNIQUE,
	ativo boolean	
);

SELECT * FROM usuarios;

CREATE TABLE caixa (
	id SERIAL PRIMARY KEY,
	usuario_id int NOT NULL,
	data_abertura TIMESTAMP DEFAULT CURRENT_TIMESTAMP current_timestamp,
	data_fechamento timestamp,
	saldo_inicial NUMERIC(10,2) NOT NULL,
	saldo_final NUMERIC(10,2)
	status VARCHAR(20) [default: 'aberto', note: 'aberto, fechado']

	CONSTRAINT fk_usuario
	FOREING KEY (usuario_id)
	REFERENCES usuario(id)
);